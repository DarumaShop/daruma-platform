{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "../../node_modules/swagger-ui-dist/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/crons/garbage-collection",
      "schedule": "0 8 * * *"
    }
  ]
}
