model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String
  price         Int
  discountPrice Int?
  stock         Int      @default(0)
  
  type          ProductType
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images          ProductImage[]
  tags            Tag[]          @relation("ProductTags")
  notebookDetails NotebookDetails?
  notepadDetails  NotepadDetails?
  posterDetails   PosterDetails?
}

enum ProductType {
  NOTEBOOK
  NOTEPAD
  POSTER
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model NotebookDetails {
  productId   String    @id
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  length      Float
  width       Float
  height      Float
  pageCount   PageCount
  paperType   PaperType
}

model NotepadDetails {
  productId   String    @id
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  length      Float
  width       Float
  height      Float
  pageCount   PageCount
  paperType   PaperType
}

model PosterDetails {
  productId   String      @id
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  size        PosterSize
  width       Float
  height      Float
}

enum PageCount {
  PAGES_60
  PAGES_80
  PAGES_100
}

enum PaperType {
  GRID
  LINED
  BLANK
}

enum PosterSize {
  SMALL
  MEDIUM
  LARGE
}
