model Product {
  id          String @id @default(uuid())
  name        String
  slug        String @unique
  description String

  type       ProductType
  isFeatured Boolean     @default(false)
  isActive   Boolean     @default(true)
  basePrice  Int         @default(0)
  maxPrice   Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images ProductImage[]
  tags   Tag[]          @relation("ProductTags")

  variants ProductVariant[]

  notebookDetails NotebookDetails?
  notepadDetails  NotepadDetails?
  posterDetails   PosterDetails?
}

model ProductVariant {
  id            String  @id @default(uuid())
  sku           String  @unique
  price         Int
  discountPrice Int?
  stock         Int     @default(0)
  isActive      Boolean @default(true)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  notebookVariantDetails NotebookVariantDetails?
  notepadVariantDetails  NotepadVariantDetails?
  posterVariantDetails   PosterVariantDetails?
}

model ProductImage {
  id  String @id @default(uuid())
  url String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model NotebookDetails {
  productId String  @id
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  length Float
  width  Float
  height Float
}

model NotepadDetails {
  productId String  @id
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  length Float
  width  Float
  height Float
}

model PosterDetails {
  productId String  @id
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  width  Float
  height Float
}

model NotebookVariantDetails {
  variantId String         @id
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  pageCount PageCount
  paperType PaperType
}

model NotepadVariantDetails {
  variantId String         @id
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  pageCount PageCount
  paperType PaperType
}

model PosterVariantDetails {
  variantId String         @id
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  size PosterSize
}

enum PageCount {
  PAGES_60
  PAGES_80
  PAGES_100
}

enum PaperType {
  GRID
  LINED
  BLANK
}

enum PosterSize {
  SMALL
  MEDIUM
  LARGE
}

enum ProductType {
  NOTEBOOK
  NOTEPAD
  POSTER
}
