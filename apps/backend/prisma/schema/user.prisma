model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  refreshToken String?
  
  role         Role     @default(USER)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}
